{
    "name": "truschery/kanon",
    "type": "library",
    "description": "PHP implementation of JSON Canonicalization Scheme (RFC 8785)",
    "license": "MIT",
    "authors": [
        {
            "name": "truschery",
            "email": "truschery.work@gmail.com"
        }
    ],
    "scripts": {
        "test": "./vendor/bin/pest"
    },
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Truschery\\Kanon\\": "src/"
        }
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },

    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
